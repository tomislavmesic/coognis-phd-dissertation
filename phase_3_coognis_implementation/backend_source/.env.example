APP_NAME=COOGNIS Prototype API
APP_PUBLIC_NAME=COOGNIS
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/coognis_prototype

AUTH_SESSION_SECRET=prototype-only-not-for-production
AUTH_SESSION_COOKIE_NAME=coognis_prototype_session
AUTH_SESSION_SAME_SITE=lax
AUTH_SESSION_HTTPS_ONLY=false
AUTH_SESSION_MAX_AGE_SECONDS=43200
AUTH_ALLOWED_ORIGINS=http://localhost:5173
AUTH_PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password

EMAIL_DELIVERY_MODE=log
EMAIL_FROM_ADDRESS=no-reply@example.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false

LLM_PROVIDER=mock
LLM_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

SYNAPSE_MODEL_DIR=./models/synapse
SYNAPSE_MODEL_DOWNLOAD_BASE_URL=
SYNAPSE_MODEL_AUTO_DOWNLOAD=false

MIND_ENABLE_SYNAPSE=true
MIND_ENABLE_UEX=true
MIND_ENABLE_ULM=true
MIND_ENABLE_PAGE=true

LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

USER_PROFILE_MIN_INTERACTIONS=3
USER_PROFILE_MIN_TEXT_CHARS=500
USER_PROFILE_REFRESH_EVERY_INTERACTIONS=5
USER_PROFILE_REFRESH_MIN_NEW_TEXT_CHARS=600
USER_PROFILE_TEXT_WINDOW_CHARS=12000

EXPERT_PROFILE_MIN_INTERACTIONS=3
EXPERT_PROFILE_MIN_TEXT_CHARS=500
EXPERT_PROFILE_REFRESH_EVERY_INTERACTIONS=5
EXPERT_PROFILE_REFRESH_MIN_NEW_TEXT_CHARS=600
EXPERT_PROFILE_TEXT_WINDOW_CHARS=12000

CHAT_TYPING_TTL_SECONDS=10
ULM_CHUNK_SIZE_CHARS=300
ULM_CHUNK_OVERLAP_CHARS=50
ULM_RETRIEVAL_MIN_SCORE=0.08
ULM_URL_FETCH_TIMEOUT_SECONDS=12
ULM_URL_MAX_CONTENT_CHARS=40000
