[
  {
    "id": "certificate-request",
    "query": "I will need my certificate that I finish all my courses. How could I get it?",
    "use_synapse": true,
    "use_uex": true,
    "use_ulm": true,
    "expect": {
      "min_uex_items": 1,
      "expected_domain_codes": ["administrative-services"],
      "expert_suggestion": true,
      "response_should_contain": ["certificate"],
      "response_should_not_contain": ["wi-fi", "internet not working"]
    }
  },
